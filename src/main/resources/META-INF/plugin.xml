<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>be.ajuvercr.swls</id>
    <idea-version since-build="233" />
    <name>SWLS - Turtle, TriG, SPARQL &amp; JSON-LD Language Server</name>

    <vendor url="https://github.com/SemanticWebLanguageServer">SemanticWebLanguageServer</vendor>

    <description><![CDATA[
        <p>Semantic Web Language Server for <strong>Turtle</strong>, <strong>TriG</strong>, <strong>SPARQL</strong> and <strong>JSON-LD</strong> —
        autocompletion, diagnostics, formatting and more.</p>

        <h3>Features</h3>
        <ul>
            <li>Autocompletion for prefixes, IRIs, properties and classes</li>
            <li>Real-time diagnostics and validation</li>
            <li>Semantic token highlighting</li>
            <li>Code formatting</li>
            <li>Inlay hints</li>
            <li>Go to definition and references</li>
            <li>SHACL shape validation</li>
            <li>Ontology-aware property suggestions</li>
        </ul>

        <h3>Supported Languages</h3>
        <ul>
            <li><strong>Turtle</strong> (.ttl)</li>
            <li><strong>TriG</strong> (.trig)</li>
            <li><strong>JSON-LD</strong> (.jsonld)</li>
            <li><strong>SPARQL</strong> (.sq, .rq)</li>
        </ul>

        <p>Powered by <a href="https://github.com/SemanticWebLanguageServer/swls">SWLS</a> —
        the Semantic Web Language Server.</p>

        <p>If you find this plugin useful, consider <a href="https://ko-fi.com/ajuvercr">supporting the author on Ko-fi</a>.</p>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>


    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Turtle"
                  implementationClass="be.ajuvercr.swls.TurtleFileType"
                  fieldName="INSTANCE"
                  extensions="ttl"/>
        <fileType name="JSON-LD"
                  implementationClass="be.ajuvercr.swls.JsonLdFileType"
                  fieldName="INSTANCE"
                  extensions="jsonld"/>
        <fileType name="SPARQL"
                  implementationClass="be.ajuvercr.swls.SparqlFileType"
                  fieldName="INSTANCE"
                  extensions="sq;rq"/>
        <fileType name="TriG"
                  implementationClass="be.ajuvercr.swls.TrigFileType"
                  fieldName="INSTANCE"
                  extensions="trig"/>
        <notificationGroup id="swls"
                           displayType="BALLOON"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="swls"
                name="Semantic Web Language Server"
                factoryClass="be.ajuvercr.swls.SwlsFactory">
            <description><![CDATA[
                Provides IDE integration for Turtle, TriG, JSON-LD, and SPARQL through a Language Server.<br/>
                Enables semantic token highlighting, validation, and code navigation support.
            ]]></description>
        </server>
        <fileNamePatternMapping patterns="*.ttl"
                                serverId="swls"
                                languageId="turtle"/>
        <fileNamePatternMapping patterns="*.jsonld"
                                serverId="swls"
                                languageId="JSON-LD"/>
        <fileNamePatternMapping patterns="*.sq;*.rq"
                                serverId="swls"
                                languageId="SPARQL"/>
        <fileNamePatternMapping patterns="*.trig"
                                serverId="swls"
                                languageId="trig"/>
    </extensions>
</idea-plugin>

